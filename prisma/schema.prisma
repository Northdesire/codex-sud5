generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════
// BRANCHEN
// ═══════════════════════════════════════════

enum Branche {
  MALER
  SHOP
  FEWO
  FAHRRAD
}

// ═══════════════════════════════════════════
// TENANT / FIRMA
// ═══════════════════════════════════════════

model Firma {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  firmenname      String
  inhaberName     String
  inhaberTitel    String?
  strasse         String
  plz             String
  ort             String
  telefon         String
  email           String
  website         String?
  steuernummer    String?
  ustIdNr         String?
  iban            String?
  bic             String?
  bankname        String?
  logoUrl         String?

  mwstSatz        Float    @default(19.0)
  stundensatz     Float    @default(47.0)
  zahlungsziel    Int      @default(14)
  angebotsGueltig Int      @default(14)
  nrPrefix        String   @default("ANG-")
  nrCounter       Int      @default(1)
  agbText         String?

  googleReviewUrl String?
  wissenstext     String?   // Freitext-Wissen für KI-gestützte Antworten

  rechnungNrPrefix  String  @default("RE-")
  rechnungNrCounter Int     @default(1)

  branche         Branche  @default(MALER)

  users           User[]
  kunden          Kunde[]
  materialien     Material[]
  leistungen      Leistung[]
  zuschlaege      Zuschlag[]
  rabatte         Rabatt[]
  raumVorlagen    RaumVorlage[]
  textVorlagen    TextVorlage[]
  angebote        Angebot[]
  rechnungen      Rechnung[]
  kalkRegeln      KalkulationsRegeln?
  produkte        Produkt[]
  komplexe        Komplex[]
  unterkuenfte    Unterkunft[]
  saisons         Saison[]
  fewoExtras      FewoExtra[]
  fahrraeder         Fahrrad[]
  mietdauerStaffeln  MietdauerStaffel[]
  fahrradExtras      FahrradExtra[]
}

// ═══════════════════════════════════════════
// USER
// ═══════════════════════════════════════════

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  rolle           Rolle    @default(INHABER)
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

enum Rolle {
  INHABER
  MITARBEITER
  BUERO
}

// ═══════════════════════════════════════════
// KUNDENSTAMM
// ═══════════════════════════════════════════

model Kunde {
  id              String    @id @default(cuid())
  firmaId         String
  firma           Firma     @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  typ             KundenTyp @default(PRIVAT)
  strasse         String?
  plz             String?
  ort             String?
  email           String?
  telefon         String?
  telefon2        String?

  notizen         String?
  stammkunde      Boolean   @default(false)
  rabattProzent   Float?

  angebote        Angebot[]
  rechnungen      Rechnung[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum KundenTyp {
  PRIVAT
  GEWERBE
  HAUSVERWALTUNG
}

// ═══════════════════════════════════════════
// MATERIALIEN
// ═══════════════════════════════════════════

model Material {
  id              String      @id @default(cuid())
  firmaId         String
  firma           Firma       @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  kategorie       MaterialKat
  artikelNr       String?

  ekPreis         Float
  vkPreis         Float
  einheit         String

  ergiebigkeit    Float?
  anstriche       Int?

  lieferant       String?
  lieferantNr     String?

  aktiv           Boolean     @default(true)
  notizen         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([firmaId, name])
}

enum MaterialKat {
  WANDFARBE
  GRUNDIERUNG
  SPACHTEL
  LACK
  VERBRAUCH
  TAPETE
  SONSTIGES
}

// ═══════════════════════════════════════════
// LEISTUNGSKATALOG
// ═══════════════════════════════════════════

model Leistung {
  id              String       @id @default(cuid())
  firmaId         String
  firma           Firma        @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  kategorie       LeistungsKat
  einheit         String

  preisProEinheit Float
  sqmProStunde    Float?

  materialKat     MaterialKat?

  beschreibung    String?
  aktiv           Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([firmaId, name])
}

enum LeistungsKat {
  STREICHEN
  VORBEREITUNG
  LACKIEREN
  FASSADE
  BODEN
  TAPEZIEREN
  TROCKENBAU
  SONSTIGES
}

// ═══════════════════════════════════════════
// PRODUKTE (SHOP-BRANCHE)
// ═══════════════════════════════════════════

model Produkt {
  id              String   @id @default(cuid())
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  kategorie       String
  artikelNr       String?
  beschreibung    String?

  ekPreis         Float
  vkPreis         Float
  einheit         String   @default("Stk.")

  aktiv           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([firmaId, name])
}

// ═══════════════════════════════════════════
// FEWO (Ferienwohnung / Hotel / Unterkunft)
// ═══════════════════════════════════════════

enum UnterkunftTyp {
  EINZELZIMMER
  DOPPELZIMMER
  SUITE
  FERIENWOHNUNG
  BENUTZERDEFINIERT
}

model Komplex {
  id            String       @id @default(cuid())
  firmaId       String
  firma         Firma        @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  name          String
  beschreibung  String?
  unterkuenfte  Unterkunft[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@unique([firmaId, name])
}

model Unterkunft {
  id              String          @id @default(cuid())
  firmaId         String
  firma           Firma           @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  komplexId       String?
  komplex         Komplex?        @relation(fields: [komplexId], references: [id], onDelete: SetNull)

  name            String
  beschreibung    String?
  typ             UnterkunftTyp   @default(FERIENWOHNUNG)
  kapazitaet      Int
  preisProNacht   Float
  aktiv           Boolean         @default(true)
  icalUrl         String?

  saisonPreise    UnterkunftPreis[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([firmaId, name])
}

model Saison {
  id              String            @id @default(cuid())
  firmaId         String
  firma           Firma             @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  von             DateTime
  bis             DateTime
  faktor          Float
  mindestaufenthalt Int @default(1)

  unterkunftPreise UnterkunftPreis[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UnterkunftPreis {
  id            String     @id @default(cuid())
  unterkunftId  String
  unterkunft    Unterkunft @relation(fields: [unterkunftId], references: [id], onDelete: Cascade)
  saisonId      String
  saison        Saison     @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  preisProNacht Float
  @@unique([unterkunftId, saisonId])
}

model FewoExtra {
  id              String   @id @default(cuid())
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  preis           Float
  einheit         String   // "pauschal", "pro Nacht", "pro Person", "pro Nacht/Person"
  unterkunftTypen String[] // z.B. ["FERIENWOHNUNG","SUITE"] — leer = gilt für alle
  aktiv           Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([firmaId, name])
}

// ═══════════════════════════════════════════
// ZUSCHLÄGE & RABATTE
// ═══════════════════════════════════════════

model Zuschlag {
  id              String   @id @default(cuid())
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  typ             WertTyp
  wert            Float
  proEinheit      String?

  automatisch     Boolean  @default(false)
  bedingung       String?
  bedingungFeld   String?
  bedingungOp     String?
  bedingungWert   Float?

  aktiv           Boolean  @default(true)
}

model Rabatt {
  id              String   @id @default(cuid())
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  typ             WertTyp
  wert            Float
  bedingung       String?
  automatisch     Boolean  @default(false)
  aktiv           Boolean  @default(true)
}

enum WertTyp {
  PROZENT
  PAUSCHAL
}

// ═══════════════════════════════════════════
// RAUM-VORLAGEN
// ═══════════════════════════════════════════

model RaumVorlage {
  id              String   @id @default(cuid())
  firmaId         String
  firma           Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  icon            String?
  laenge          Float
  breite          Float
  hoehe           Float
  fenster         Int      @default(1)
  tueren          Int      @default(1)
  sortierung      Int      @default(0)

  @@unique([firmaId, name])
}

// ═══════════════════════════════════════════
// KALKULATIONSREGELN
// ═══════════════════════════════════════════

model KalkulationsRegeln {
  id                   String  @id @default(cuid())
  firmaId              String  @unique
  firma                Firma   @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  verschnittFaktor     Float   @default(10.0)
  standardAnstriche    Int     @default(2)
  grundierungImmer     Boolean @default(true)
  abklebebandProRaum   Int     @default(2)
  abdeckfolieProRaum   Int     @default(1)
  acrylProRaum         Int     @default(0)

  anfahrtKlein         Float   @default(35.0)
  anfahrtGross         Float   @default(55.0)
  anfahrtSchwelle      Int     @default(3)

  standardQualitaet    String  @default("standard")
  deckeStandard        Boolean @default(false)
  grundierungStandard  Boolean @default(true)
  zuschlagAutoErkennen Boolean @default(true)

  fensterAbzug         Float   @default(1.5)
  tuerAbzug            Float   @default(2.0)
}

// ═══════════════════════════════════════════
// TEXTVORLAGEN
// ═══════════════════════════════════════════

model TextVorlage {
  id              String      @id @default(cuid())
  firmaId         String
  firma           Firma       @relation(fields: [firmaId], references: [id], onDelete: Cascade)

  name            String
  typ             VorlagenTyp
  betreff         String?
  text            String
  aktiv           Boolean     @default(true)
}

enum VorlagenTyp {
  ANGEBOT_INTRO
  ANGEBOT_SCHLUSS
  RECHNUNG_INTRO
  RECHNUNG_SCHLUSS
  FOLLOWUP_TAG3
  FOLLOWUP_TAG7
  FOLLOWUP_TAG12
  GOOGLE_BEWERTUNG
  SONSTIGE
}

// ═══════════════════════════════════════════
// ANGEBOTE
// ═══════════════════════════════════════════

model Angebot {
  id              String         @id @default(cuid())
  firmaId         String
  firma           Firma          @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  kundeId         String?
  kunde           Kunde?         @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  nummer          String
  datum           DateTime       @default(now())
  gueltigBis      DateTime

  status          AngebotsStatus @default(OFFEN)
  statusAenderung DateTime?

  eingabeMethode  EingabeMethode
  originalText    String?

  kundeName       String
  kundeStrasse    String?
  kundePlz        String?
  kundeOrt        String?
  kundeEmail      String?
  kundeTelefon    String?

  // FEWO-spezifische Felder
  anreise         DateTime?
  abreise         DateTime?
  naechte         Int?
  personen        Int?

  positionen      AngebotPosition[]
  materialNetto   Float
  arbeitsNetto    Float
  anfahrt         Float
  zuschlagNetto   Float          @default(0)
  rabattNetto     Float          @default(0)
  netto           Float
  mwstBetrag      Float
  brutto          Float

  einleitungsText String?
  schlussText     String?

  pdfUrl          String?

  rechnung        Rechnung?
  followUps       FollowUp[]
  bewertungAngefragt Boolean     @default(false)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum AngebotsStatus {
  ENTWURF
  OFFEN
  ANGENOMMEN
  ABGELEHNT
  ABGELAUFEN
}

enum EingabeMethode {
  SPRACHE
  TEXT_EMAIL
  TEXT_WHATSAPP
  TEXT_SONSTIG
  FORMULAR
}

// ═══════════════════════════════════════════
// ANGEBOTS-POSITIONEN
// ═══════════════════════════════════════════

model AngebotPosition {
  id              String       @id @default(cuid())
  angebotId       String
  angebot         Angebot      @relation(fields: [angebotId], references: [id], onDelete: Cascade)

  posNr           Int
  typ             PositionsTyp

  raumName        String?
  raumLaenge      Float?
  raumBreite      Float?
  raumHoehe       Float?
  raumFenster     Int?
  raumTueren      Int?
  wandflaeche     Float?
  deckenflaeche   Float?

  bezeichnung     String
  menge           Float
  einheit         String
  einzelpreis     Float
  gesamtpreis     Float

  leistungId      String?
  materialId      String?

  sortierung      Int          @default(0)
}

enum PositionsTyp {
  LEISTUNG
  MATERIAL
  ZUSCHLAG
  RABATT
  ANFAHRT
  PRODUKT
}

// ═══════════════════════════════════════════
// FOLLOW-UP TRACKING
// ═══════════════════════════════════════════

model FollowUp {
  id               String         @id @default(cuid())
  angebotId        String
  angebot          Angebot        @relation(fields: [angebotId], references: [id], onDelete: Cascade)

  typ              FollowUpTyp
  geplanterVersand DateTime
  gesendetAm       DateTime?
  status           FollowUpStatus @default(GEPLANT)
  kanal            String         @default("email")
}

enum FollowUpTyp {
  TAG3
  TAG7
  TAG12
  GOOGLE_BEWERTUNG
}

enum FollowUpStatus {
  GEPLANT
  GESENDET
  ABGEBROCHEN
}

// ═══════════════════════════════════════════
// RECHNUNGEN (SHOP-BRANCHE)
// ═══════════════════════════════════════════

enum RechnungsStatus {
  ENTWURF
  OFFEN
  BEZAHLT
  STORNIERT
}

model Rechnung {
  id              String           @id @default(cuid())
  firmaId         String
  firma           Firma            @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  kundeId         String?
  kunde           Kunde?           @relation(fields: [kundeId], references: [id], onDelete: SetNull)
  angebotId       String?          @unique
  angebot         Angebot?         @relation(fields: [angebotId], references: [id], onDelete: SetNull)
  nummer          String
  datum           DateTime         @default(now())
  faelligAm       DateTime
  status          RechnungsStatus  @default(ENTWURF)
  statusAenderung DateTime?
  bezahltAm       DateTime?
  kundeName       String
  kundeStrasse    String?
  kundePlz        String?
  kundeOrt        String?
  kundeEmail      String?
  kundeTelefon    String?
  positionen      RechnungPosition[]
  netto           Float
  mwstSatz        Float
  mwstBetrag      Float
  brutto          Float
  einleitungsText String?
  schlussText     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RechnungPosition {
  id          String       @id @default(cuid())
  rechnungId  String
  rechnung    Rechnung     @relation(fields: [rechnungId], references: [id], onDelete: Cascade)
  posNr       Int
  typ         PositionsTyp
  bezeichnung String
  menge       Float
  einheit     String
  einzelpreis Float
  gesamtpreis Float
  sortierung  Int          @default(0)
}

// ═══════════════════════════════════════════
// FAHRRAD (Fahrradverleih)
// ═══════════════════════════════════════════

model Fahrrad {
  id            String         @id @default(cuid())
  firmaId       String
  firma         Firma          @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  name          String
  kategorie     String
  beschreibung  String?
  preisProTag   Float
  aktiv         Boolean        @default(true)
  staffelPreise FahrradPreis[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  @@unique([firmaId, name])
}

model MietdauerStaffel {
  id       String         @id @default(cuid())
  firmaId  String
  firma    Firma          @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  name     String
  bisTag   Int
  preise   FahrradPreis[]
  @@unique([firmaId, bisTag])
}

model FahrradPreis {
  id          String           @id @default(cuid())
  fahrradId   String
  fahrrad     Fahrrad          @relation(fields: [fahrradId], references: [id], onDelete: Cascade)
  staffelId   String
  staffel     MietdauerStaffel @relation(fields: [staffelId], references: [id], onDelete: Cascade)
  preisProTag Float
  @@unique([fahrradId, staffelId])
}

model FahrradExtra {
  id        String   @id @default(cuid())
  firmaId   String
  firma     Firma    @relation(fields: [firmaId], references: [id], onDelete: Cascade)
  name      String
  preis     Float
  einheit   String
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
